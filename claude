import streamlit as st
import random

# 페이지 기본 설정
st.set_page_config(
    page_title="Make New World 🌍",
    page_icon="🌍",
    layout="centered"
)

# 제목
st.title('🌍 Make New World! ❤️')
st.write('✨ 새로운 세계를 함께 만들어봐요! ✨')

st.divider()

# 세계 이름 짓기
st.header('📝 1단계: 새로운 세계의 이름을 지어주세요!')
world_name = st.text_input('세계 이름을 입력하세요', placeholder='예: 별빛 왕국, 구름 나라...')

if world_name:
    st.success(f'✅ **{world_name}** 이 탄생했어요! 🎉')

st.divider()

# 세계 환경 선택
st.header('🌈 2단계: 세계의 환경을 선택하세요!')
environment = st.selectbox(
    '어떤 환경의 세계인가요?',
    ['🌊 바다 세계', '🌲 숲 세계', '🏔️ 산악 세계', 
     '🌌 우주 세계', '🏜️ 사막 세계', '❄️ 얼음 세계']
)

st.info(f'선택한 환경: **{environment}**')

st.divider()

# 세계의 특징 다중 선택
st.header('⚡ 3단계: 세계의 특별한 능력을 골라주세요!')
features = st.multiselect(
    '원하는 특징을 모두 선택하세요 (여러 개 가능!)',
    ['🦋 마법이 존재한다', '🤖 첨단 기술이 발달했다', 
     '🐉 신화 속 동물이 산다', '🌺 식물이 말을 한다',
     '⭐ 별이 소원을 들어준다', '🎵 음악으로 세계가 움직인다']
)

if features:
    st.write('선택한 특징들:')
    for f in features:
        st.write(f'  - {f}')

st.divider()

# 세계 인구 슬라이더
st.header('👥 4단계: 세계의 인구를 설정하세요!')
population = st.slider(
    '인구 수 (만 명)',
    min_value=1,
    max_value=1000,
    value=100,
    step=10
)
st.write(f'🌏 이 세계의 인구는 **{population}만 명** 입니다!')

st.divider()

# 세계 생성 버튼
st.header('🚀 5단계: 세계를 완성하세요!')

if st.button('🌟 새로운 세계 생성하기!', use_container_width=True):
    if world_name:
        st.balloons()  # 풍선 애니메이션 🎈
        st.success('🎊 새로운 세계가 탄생했습니다!')

        st.markdown(f"""
        ## 🌍 {world_name} 세계 정보
        ---
        - 🌏 **환경**: {environment}
        - 👥 **인구**: {population}만 명
        - ⚡ **특징**: {', '.join(features) if features else '없음'}
        - 🎲 **세계 번호**: #{random.randint(1000, 9999)}
        ---
        > 💬 *"{world_name}는 오늘부터 새로운 역사를 시작합니다!"*
        """)
    else:
        st.warning('⚠️ 먼저 세계의 이름을 입력해주세요!')

# 하단 마무리
st.divider()
st.caption('💡 당신의 상상력으로 새로운 세계를 만들어보세요! 🚀')
